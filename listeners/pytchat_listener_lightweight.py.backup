# ========== LIGHTWEIGHT PYTCHAT LISTENER ==========
# 🚀 OPTIMIZED VERSION untuk mengatasi UI freeze dan "not responding"

import sys
import os
from pathlib import Path
import threading
import time
import json
import queue
from concurrent.futures import ThreadPoolExecutor
import asyncio

# Handle pytchat import
try:
    import pytchat
    print("[DEBUG] PyTchat imported directly")
except ImportError:
    print("[DEBUG] Direct pytchat import failed, trying thirdparty...")
    
    if getattr(sys, 'frozen', False):
        application_path = Path(sys.executable).parent
    else:
        application_path = Path(__file__).resolve().parent.parent
    
    thirdparty_path = application_path / "thirdparty" / "pytchat_ng"
    if thirdparty_path.exists():
        sys.path.insert(0, str(thirdparty_path))
        try:
            import pytchat
            print("[DEBUG] PyTchat imported from thirdparty successfully")
        except ImportError as e:
            print(f"[ERROR] Failed to import pytchat from thirdparty: {e}")
            raise
    else:
        print(f"[ERROR] Thirdparty path not found: {thirdparty_path}")
        raise ImportError("PyTchat not found")

class LightweightPytchatListener:
    """🚀 Lightweight pytchat listener yang tidak memblokir UI"""
    
    def __init__(self, video_id, callback, trigger_words=None, reply_mode="Trigger"):
        self.video_id = video_id
        self.callback = callback
        self.is_running = False
        self.chat = None
        
        # ⚡ LIGHTWEIGHT: Message queue untuk async processing
        self.message_queue = queue.Queue(maxsize=200)  # Increased for real-time
        self.executor = ThreadPoolExecutor(max_workers=3, thread_name_prefix="pytchat")  # More workers
        
        # ⚡ REAL-TIME CONFIG: Accept trigger words from UI
        self.reply_mode = reply_mode
        self.trigger_words = [word.lower().strip() for word in (trigger_words or ["halo", "bang", "min"])]
        self.delay_seconds = 5
        
        # ⚡ LIGHTWEIGHT: Message deduplication
        self.seen_messages = set()
        self.last_message_time = 0
        
        print(f"[LIGHTWEIGHT] Initialized for video: {video_id}")
        print(f"[LIGHTWEIGHT] Trigger words: {self.trigger_words}")
        print(f"[LIGHTWEIGHT] Reply mode: {self.reply_mode}")

    def start(self):
        """🚀 Start lightweight listener"""
        try:
            print(f"[LIGHTWEIGHT] Starting listener for {self.video_id}")
            
            # ⚡ FAST: Create chat object
            self.chat = pytchat.create(video_id=self.video_id)
            if not self.chat:
                print("[LIGHTWEIGHT] Failed to create chat object")
                return False
            
            self.is_running = True
            
            # ⚡ ASYNC: Start message fetcher in separate thread
            self.executor.submit(self._message_fetcher)
            
            # ⚡ ASYNC: Start message processor in separate thread  
            self.executor.submit(self._message_processor)
            
            print("[LIGHTWEIGHT] Listener started successfully")
            return True
            
        except Exception as e:
            print(f"[LIGHTWEIGHT] Error starting listener: {e}")
            return False

    def _message_fetcher(self):
        """⚡ LIGHTWEIGHT: Fetch messages without blocking UI"""
        print("[LIGHTWEIGHT] Message fetcher started")
        
        try:
            while self.is_running and self.chat and self.chat.is_alive():
                try:
                    # ⚡ FAST: Get messages with minimal processing
                    items = self.chat.get().sync_items()
                    
                    for item in items:
                        if not self.is_running:
                            break
                            
                        # ⚡ LIGHTWEIGHT: Quick message validation
                        if self._is_valid_message(item):
                            try:
                                # ⚡ NON-BLOCKING: Add to queue without waiting
                                self.message_queue.put_nowait({
                                    'author': item.author.name,
                                    'message': item.message,
                                    'timestamp': time.time()
                                })
                            except queue.Full:
                                # ⚡ LIGHTWEIGHT: Drop old messages if queue full
                                try:
                                    self.message_queue.get_nowait()
                                    self.message_queue.put_nowait({
                                        'author': item.author.name,
                                        'message': item.message,
                                        'timestamp': time.time()
                                    })
                                except queue.Empty:
                                    pass
                    
                    # ⚡ REAL-TIME: Minimal sleep untuk real-time performance
                    time.sleep(0.01)  # Reduced from 0.1 for real-time comments
                    
                except Exception as e:
                    print(f"[LIGHTWEIGHT] Error in message fetcher: {e}")
                    time.sleep(1)  # Wait before retry
                    
        except Exception as e:
            print(f"[LIGHTWEIGHT] Fatal error in message fetcher: {e}")
        
        print("[LIGHTWEIGHT] Message fetcher stopped")

    def _message_processor(self):
        """⚡ LIGHTWEIGHT: Process messages asynchronously"""
        print("[LIGHTWEIGHT] Message processor started")
        
        try:
            while self.is_running:
                try:
                    # ⚡ NON-BLOCKING: Get message with timeout
                    msg_data = self.message_queue.get(timeout=1.0)
                    
                    author = msg_data['author']
                    message = msg_data['message']
                    
                    # ⚡ FAST: Simple trigger check
                    if self._should_respond(message):
                        print(f"[LIGHTWEIGHT] Processing: {author}: {message}")
                        
                        # ⚡ ASYNC: Call callback in separate thread to avoid blocking
                        # Only submit if still running to prevent shutdown errors
                        if self.is_running:
                            try:
                                self.executor.submit(self._safe_callback, author, message)
                            except RuntimeError as e:
                                if "cannot schedule new futures after shutdown" in str(e):
                                    print("[LIGHTWEIGHT] Executor shutdown, stopping message processing")
                                    break
                                else:
                                    print(f"[LIGHTWEIGHT] Error submitting task: {e}")
                    
                except queue.Empty:
                    continue
                except Exception as e:
                    print(f"[LIGHTWEIGHT] Error processing message: {e}")
                    
        except Exception as e:
            print(f"[LIGHTWEIGHT] Fatal error in message processor: {e}")
        
        print("[LIGHTWEIGHT] Message processor stopped")

    def _is_valid_message(self, item):
        """⚡ FAST: Lightweight message validation"""
        try:
            # ⚡ FAST: Basic checks only
            if not item or not item.author or not item.message:
                return False
            
            # ⚡ FAST: Simple deduplication
            msg_id = f"{item.author.name}:{item.message[:50]}"
            if msg_id in self.seen_messages:
                return False
            
            # ⚡ LIGHTWEIGHT: Keep only recent messages in memory
            if len(self.seen_messages) > 1000:
                self.seen_messages.clear()
            
            self.seen_messages.add(msg_id)
            return True
            
        except Exception:
            return False

    def _should_respond(self, message):
        """⚡ FAST: Pass ALL messages to UI for real-time viewing"""
        try:
            # ✅ PERBAIKAN UTAMA: Selalu return True untuk menampilkan semua komentar
            # Trigger detection akan dilakukan di UI level (_enqueue_lightweight)
            return True
            
        except Exception:
            return False

    def _safe_callback(self, author, message):
        """⚡ SAFE: Execute callback with error handling"""
        try:
            if self.is_running:  # Only execute if still running
                self.callback(author, message)
        except Exception as e:
            print(f"[LIGHTWEIGHT] Error in callback: {e}")

    def stop(self):
        """🛑 Stop listener gracefully"""
        print("[LIGHTWEIGHT] Stopping listener...")
        self.is_running = False
        
        # Wait a moment for threads to notice the stop signal
        time.sleep(0.1)
        
        try:
            if self.chat:
                self.chat.terminate()
        except Exception as e:
            print(f"[LIGHTWEIGHT] Error stopping chat: {e}")
        
        try:
            # Shutdown executor gracefully with a short wait
            self.executor.shutdown(wait=True, timeout=2.0)
        except Exception as e:
            print(f"[LIGHTWEIGHT] Error shutting down executor: {e}")
        
        print("[LIGHTWEIGHT] Listener stopped")

def start_lightweight_pytchat_listener(video_id, callback, trigger_words=None, reply_mode="Trigger"):
    """🚀 Start lightweight pytchat listener with configurable trigger words"""
    listener = LightweightPytchatListener(video_id, callback, trigger_words, reply_mode)
    if listener.start():
        return listener
    return None